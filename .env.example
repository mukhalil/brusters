# Database (Neon Postgres)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/brusters?sslmode=require

# Staff dashboard PIN (4-6 digits)
STAFF_PIN=1234

# Payment provider: 'mock' or 'square'
PAYMENT_PROVIDER=mock

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Square (future)
SQUARE_APPLICATION_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox
